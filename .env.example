# Copy to .env for local development. Never commit real secrets.
APP_ENV=development
PORT=8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_SHUTDOWN_TIMEOUT=10s

# Database (goose migrations and PostgresGenerationRepo both use this).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/pricing?sslmode=disable

# Frontend origin(s) allowed to call this API cross-origin (comma-separated).
# The frontend is always a separate origin — a separate Next.js repo/deploy —
# in every environment (local dev on a different port, Vercel calling Cloud
# Run in production), so this is never optional.
ALLOWED_ORIGINS=http://localhost:3000

# LLM provider selection: "anthropic" (dev) or "groq" (prod). See ADR-0003.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# Rate limiting (fixed window per caller IP, see ADR-0006). Local Redis for
# development; Upstash's endpoint/password in production. REDIS_TLS_ENABLED
# must be true for Upstash (TLS-only) and false for the local dev container
# (doesn't speak TLS at all).
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_TLS_ENABLED=false
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=1m

# How many reverse-proxy hops sit in front of this server, deciding whether
# the rate limiter's client-IP key comes from the raw TCP peer address (0,
# correct here — local dev has no reverse proxy) or from a trusted hop of
# X-Forwarded-For. Cloud Run production sets this to 1 (see deploy.yml).
TRUSTED_PROXY_HOPS=0

# How long an Idempotency-Key on POST /v1/generate stays mapped to its
# generation (same Redis instance as rate limiting). See issue #23. Also
# backs POST /v1/generate's implicit content-based caching (issue #24) when
# no Idempotency-Key header is sent.
IDEMPOTENCY_TTL=24h

# How long a POST /v1/analyze response is cached, keyed on the submitted
# URL. See issue #24.
ANALYZE_CACHE_TTL=1h

# OpenTelemetry tracing. Empty (the default) means no-op: no collector is
# provisioned until Sprint 7's Grafana Cloud setup. See ADR-0007. Setting
# this to a collector/Grafana Cloud OTLP endpoint enables real export; every
# other OTEL_EXPORTER_OTLP_* var (headers, compression, ...) also applies if set.
OTEL_EXPORTER_OTLP_ENDPOINT=

# Sentry error tracking (issue #40). Empty (the default) means no-op — see
# telemetry.InitSentry. Not a secret, same reasoning as the frontend's
# NEXT_PUBLIC_SENTRY_DSN: Sentry's own docs describe the DSN as safe to
# expose (submit-only endpoint identifier). Uses a separate Sentry project
# from the frontend's (same org) so backend/frontend errors don't mix.
SENTRY_DSN=
